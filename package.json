{
  "name": "osinthub",
  "version": "2.1.0",
  "description": "Profesyonel OSINT ve Forensics Aracı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "OsintHub",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "exif-parser": "^0.1.12",
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^7.0.2",
    "libphonenumber-js": "^1.10.51",
    "p-queue": "^6.6.2",
    "pdfkit": "^0.14.0",
    "socks-proxy-agent": "^8.0.2"
  },
  "build": {
    "appId": "com.osinthub.app",
    "productName": "OsintHub",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "OsintHubPortable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
