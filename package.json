{
  "name": "osinthub",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.2",
    "exif-parser": "^0.1.12",
    "http-proxy-agent": "^5.0.0",
    "https-proxy-agent": "^5.0.1",
    "libphonenumber-js": "^1.10.0",
    "p-queue": "^6.6.2",
    "pdfkit": "^0.13.0",
    "socks-proxy-agent": "^7.0.0"
  },
  "build": {
    "appId": "com.osinthub.app",
    "productName": "OsintHub",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "node_modules/**/*"
    ]
  }
}
